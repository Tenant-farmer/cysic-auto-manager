{
  "name": "cysic-auto-manager",
  "version": "0.1.0",
  "description": "Cysic mainnet 다중 지갑 자동 관리 툴 — 클레임, 수집, BNB 브릿지까지 한번에",
  "main": "dist/index.js",
  "license": "MIT",
  "keywords": [
    "cysic",
    "cosmos",
    "ethermint",
    "bnb",
    "bridge",
    "staking",
    "auto-claim",
    "multi-wallet"
  ],
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "balance": "ts-node src/index.ts balance",
    "claim": "ts-node src/index.ts claim",
    "collect": "ts-node src/index.ts collect",
    "bridge": "ts-node src/index.ts bridge",
    "run-all": "ts-node src/index.ts run-all",
    "migrate": "ts-node scripts/migrate-to-secrets.ts",
    "doctor": "ts-node scripts/doctor.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@cosmjs/proto-signing": "^0.32.4",
    "@cosmjs/stargate": "^0.32.4",
    "@cosmjs/encoding": "^0.32.4",
    "cosmjs-types": "^0.9.0",
    "ethers": "^6.13.2",
    "dotenv": "^16.4.5",
    "commander": "^12.1.0",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "ts-node": "^10.9.2",
    "@types/node": "^20.14.10"
  }
}
