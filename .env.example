# ============================================================
# Cysic Auto Manager - 환경변수 템플릿
#
# 이 파일은 git 에 커밋되는 공개 템플릿입니다.
# 실제 사용 시 .env 로 복사하고 값을 채우세요.
#
#   PowerShell:  Copy-Item .env.example .env
#   Bash:        cp .env.example .env
#
# ⚠️ mnemonic 은 이 파일이 아니라 .secrets/ 폴더에 별도 저장합니다.
#     자세한 방법: .secrets/README.md
# ============================================================

# ----- Cysic 체인 정보 (mainnet) -----
CYSIC_CHAIN_ID=cysicmint_4399-1
CYSIC_RPC_URL=https://rpc.cysic.xyz
CYSIC_REST_URL=https://rest.cysic.xyz
CYSIC_EVM_RPC_URL=https://rpc-evm.cysic.xyz
CYSIC_EVM_CHAIN_ID=4399
CYSIC_BECH32_PREFIX=cysic
# Cysic 은 dual-token: CYS (보상/전송), CGT (스테이킹 표시)
CYSIC_DENOM=CYS
CYSIC_STAKING_DENOM=CGT
CYSIC_DECIMALS=18
# Cysic mempool 최소 gas price 는 7 unit/gas. 정수로 7 이상 권장.
CYSIC_GAS_PRICE=10CYS

# ----- BNB Smart Chain -----
BNB_RPC_URL=https://bsc-dataseed.binance.org
BNB_CHAIN_ID=56

# ----- 본인의 메인 지갑 주소 (cysic1... 형식) -----
# 보상이 모일 지갑의 bech32 주소. 니모닉은 .secrets/main.mnemonic 에.
MAIN_WALLET_ADDRESS=

# ----- 브릿지 (Cysic → BNB) -----
# Cysic 측 MainBridge proxy (2026-05 시점 검증된 주소)
BRIDGE_CONTRACT_ADDRESS=0x127e8564bF37d179Bf6cC57a6209a3dacB6F9045
# BNB 체인에서 CYS BEP-20 토큰을 받을 본인의 0x 주소
BRIDGE_RECIPIENT_BNB_ADDRESS=

# ----- 동작 설정 -----
# 서브 지갑에 가스용으로 남길 최소 잔액 (CYS)
MIN_KEEP_AMOUNT=0.1
# 브릿지 최소 금액 (CYS). 브릿지 fee 가 약 2 CYS 이므로 그 이상이어야 의미 있음.
MIN_BRIDGE_AMOUNT=1
# DRY_RUN=true 면 실제 트랜잭션은 보내지 않고 시뮬레이션만
DRY_RUN=true
