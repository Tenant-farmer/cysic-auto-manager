# ============================================================
# Cysic Auto Manager — Environment Template
#
# This file is a public template tracked in git.
# Copy to .env and fill in the blanks before running.
#
#   PowerShell:  Copy-Item .env.example .env
#   Bash:        cp .env.example .env
#
# ⚠️ Mnemonics are NOT stored here. They live in .secrets/.
#    See .secrets/README.md for details.
# ============================================================
# 이 파일은 git 에 커밋되는 공개 템플릿입니다.
# 실제 사용 시 .env 로 복사하고 값을 채우세요.
# ⚠️ mnemonic 은 이 파일이 아니라 .secrets/ 폴더에 별도 저장합니다.
# ============================================================

# ----- Cysic chain (mainnet) -----
CYSIC_CHAIN_ID=cysicmint_4399-1
CYSIC_RPC_URL=https://rpc.cysic.xyz
CYSIC_REST_URL=https://rest.cysic.xyz
CYSIC_EVM_RPC_URL=https://rpc-evm.cysic.xyz
CYSIC_EVM_CHAIN_ID=4399
CYSIC_BECH32_PREFIX=cysic
# Cysic is dual-token: CYS (rewards/transfer), CGT (staking only)
# Cysic 은 dual-token: CYS (보상/전송), CGT (스테이킹 표시)
CYSIC_DENOM=CYS
CYSIC_STAKING_DENOM=CGT
CYSIC_DECIMALS=18
# Mempool min gas price is 7 unit/gas. Use an integer >= 7.
# Cysic mempool 최소 gas price 는 7 unit/gas. 정수로 7 이상 권장.
CYSIC_GAS_PRICE=10CYS

# ----- BNB Smart Chain -----
BNB_RPC_URL=https://bsc-dataseed.binance.org
BNB_CHAIN_ID=56

# ----- Your main wallet address (cysic1... bech32) -----
# Mnemonic goes in .secrets/main.mnemonic (not here).
# 니모닉은 .secrets/main.mnemonic 에.
MAIN_WALLET_ADDRESS=

# ----- Bridge (Cysic → BNB) -----
# Cysic-side MainBridge proxy (verified as of May 2026)
BRIDGE_CONTRACT_ADDRESS=0x127e8564bF37d179Bf6cC57a6209a3dacB6F9045
# Your 0x address on BNB Chain that will receive CYS BEP-20
# BNB 체인에서 CYS BEP-20 토큰을 받을 본인의 0x 주소
BRIDGE_RECIPIENT_BNB_ADDRESS=

# ----- Runtime options -----
# Minimum balance to leave in sub-wallets (for future gas fees), in CYS
# 서브 지갑에 가스용으로 남길 최소 잔액 (CYS)
MIN_KEEP_AMOUNT=0.1
# Minimum bridge amount. Bridge fee is ~2 CYS flat, so anything below 2 CYS
# results in 0 arriving. Set this to your acceptable threshold.
# 브릿지 최소 금액. fee 가 약 2 CYS 고정이므로 그 이상이어야 의미 있음.
MIN_BRIDGE_AMOUNT=1
# Set DRY_RUN=true to simulate without broadcasting. Recommended for first runs.
# DRY_RUN=true 면 실제 트랜잭션은 보내지 않고 시뮬레이션만
DRY_RUN=true
